# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/media_pipeline

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# App Configuration
PORT=3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# AWS S3 Configuration (Optional - for cloud storage)
# Note: Since you are using AWS Academy, you MUST include the AWS_SESSION_TOKEN
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# Worker
WORKER_CONCURRENCY=3

# Analysis thresholds (optional overrides)
BLUR_THRESHOLD=100
BRIGHTNESS_MIN=40
BRIGHTNESS_MAX=210
DUPLICATE_HAMMING_DISTANCE=10
